<!DOCTYPE html>
<html>
  <head>
    <title>LegalPromptHub</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <!-- 고정 헤더 -->
    <header class="sticky top-0 z-50 bg-white border-b border-gray-200 backdrop-blur bg-white/90">
      <nav class="mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <!-- 로고 -->
          <div class="flex items-center">
            <%= link_to root_path, class: "flex items-center space-x-2 group" do %>
              <span class="text-2xl font-bold text-gray-900 group-hover:text-emerald-600 transition-colors">
                Legal<span class="text-emerald-600">Prompt</span>Hub
              </span>
            <% end %>
          </div>
          
          <!-- 네비게이션 -->
          <div class="flex items-center space-x-4">
            <% if user_signed_in? %>
              <%= link_to "프롬프트 둘러보기", legal_prompts_path, 
                  class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium transition-colors" %>
              <%= link_to "새 프롬프트", new_legal_prompt_path, 
                  class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium transition-colors" %>
              
              <div class="flex items-center space-x-3 pl-3 border-l border-gray-200">
                <span class="text-sm text-gray-600"><%= current_user.name %></span>
                <%= button_to "로그아웃", destroy_user_session_path, method: :delete, 
                    class: "text-sm text-gray-500 hover:text-gray-700 font-medium transition-colors" %>
              </div>
            <% else %>
              <%= link_to "로그인", new_user_session_path, 
                  class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium transition-colors" %>
              <%= link_to "회원가입", new_user_registration_path, 
                  class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg text-white bg-emerald-600 hover:bg-emerald-700 transition-all duration-200" %>
            <% end %>
          </div>
        </div>
      </nav>
    </header>
    
    <% if notice.present? %>
      <div class="max-w-4xl mx-auto px-4 mt-4">
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative" role="alert">
          <span class="block sm:inline"><%= notice %></span>
        </div>
      </div>
    <% end %>
    
    <% if alert.present? %>
      <div class="max-w-4xl mx-auto px-4 mt-4">
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
          <span class="block sm:inline"><%= alert %></span>
        </div>
      </div>
    <% end %>
    
    <main>
      <%= yield %>
    </main>
  </body>
</html>
<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-800">LegalPromptHub</h1>
      <p class="text-gray-600 mt-2">변호사를 위한 AI 프롬프트</p>
    </div>
    <% if user_signed_in? %>
      <%= link_to "✚ 새 프롬프트 등록", new_legal_prompt_path, 
          class: "inline-flex items-center px-6 py-3 bg-emerald-600 text-white font-medium rounded-lg hover:bg-emerald-700 transition duration-200" %>
    <% else %>
      <%= link_to "로그인", new_user_session_path, 
          class: "inline-flex items-center px-6 py-3 bg-emerald-600 text-white font-medium rounded-lg hover:bg-emerald-700 transition duration-200" %>
    <% end %>
  </div>
  
  <div class="bg-white rounded-lg shadow-sm">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-semibold text-gray-800">모든 프롬프트</h3>
    </div>
    
    <div class="divide-y divide-gray-200">
      <% if @legal_prompts.any? %>
        <% @legal_prompts.each do |prompt| %>
          <div class="px-6 py-4 hover:bg-gray-50 transition duration-150">
            <%= link_to prompt, class: "block" do %>
              <h4 class="text-base font-medium text-gray-800 mb-1"><%= prompt.title %></h4>
              <div class="flex items-center text-sm text-gray-500 space-x-3">
                <span class="bg-gray-100 px-2 py-1 rounded"><%= prompt.category_korean %></span>
                <span><%= prompt.user.name %></span>
                <span><%= time_ago_in_words(prompt.created_at) %>전</span>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="px-6 py-8 text-center text-gray-500">
          아직 등록된 프롬프트가 없습니다.
        </div>
      <% end %>
    </div>
  </div>
</div>
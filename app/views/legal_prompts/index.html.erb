<!-- Hero Section -->
<div class="relative overflow-hidden bg-gradient-to-br from-emerald-50 via-white to-green-50">
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-100/20 via-transparent to-green-100/20"></div>
    <div class="absolute top-0 right-0 -mt-16 -mr-16 w-80 h-80 bg-emerald-200/30 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-80 h-80 bg-green-200/30 rounded-full blur-3xl"></div>
  </div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center">
      <h1 class="text-5xl sm:text-6xl font-extrabold text-gray-900 tracking-tight">
        Legal<span class="text-emerald-600">Prompt</span>Hub
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-xl text-gray-600">
        변호사를 위한 AI 프롬프트 플랫폼으로<br class="sm:hidden" />
        업무 효율성을 극대화하세요
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <% if user_signed_in? %>
          <%= link_to new_legal_prompt_path, 
              class: "inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-xl text-white bg-gradient-to-r from-emerald-600 to-emerald-700 hover:from-emerald-700 hover:to-emerald-800 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            새 프롬프트 등록
          <% end %>
          <%= link_to legal_prompts_path, 
              class: "inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-xl text-emerald-700 bg-white border-2 border-emerald-200 hover:bg-emerald-50 transform hover:scale-105 transition-all duration-200 shadow-md hover:shadow-lg" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
            프롬프트 둘러보기
          <% end %>
        <% else %>
          <%= link_to new_user_session_path, 
              class: "inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-xl text-white bg-gradient-to-r from-emerald-600 to-emerald-700 hover:from-emerald-700 hover:to-emerald-800 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path>
            </svg>
            로그인하기
          <% end %>
          <%= link_to new_user_registration_path, 
              class: "inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-xl text-emerald-700 bg-white border-2 border-emerald-200 hover:bg-emerald-50 transform hover:scale-105 transition-all duration-200 shadow-md hover:shadow-lg" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
            </svg>
            무료로 시작하기
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Features Section -->
<div class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-emerald-100 rounded-2xl mb-4">
          <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">빠른 업무 처리</h3>
        <p class="text-gray-600">검증된 AI 프롬프트로<br />법률 업무를 신속하게 처리하세요</p>
      </div>
      <div class="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-emerald-100 rounded-2xl mb-4">
          <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">맞춤형 프롬프트</h3>
        <p class="text-gray-600">7가지 카테고리별로<br />정리된 전문 프롬프트</p>
      </div>
      <div class="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-emerald-100 rounded-2xl mb-4">
          <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">전문가 커뮤니티</h3>
        <p class="text-gray-600">동료 변호사들과<br />프롬프트를 공유하세요</p>
      </div>
    </div>
  </div>
</div>

<!-- Prompts Section -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8">
    <div>
      <h2 class="text-3xl font-bold text-gray-900">최신 프롬프트</h2>
      <p class="text-gray-600 mt-2">변호사들이 공유한 최신 AI 프롬프트를 확인하세요</p>
      <% if @current_tag.present? %>
        <div class="mt-3 flex items-center gap-2">
          <span class="text-sm text-gray-600">태그 필터:</span>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-emerald-100 text-emerald-800">
            #<%= @current_tag %>
          </span>
          <%= link_to "필터 제거", legal_prompts_path, 
              class: "text-sm text-emerald-600 hover:text-emerald-700" %>
        </div>
      <% end %>
    </div>
    <% if user_signed_in? %>
      <div class="mt-4 sm:mt-0">
        <%= link_to "모든 프롬프트 보기 →", legal_prompts_path, 
            class: "text-emerald-600 hover:text-emerald-700 font-medium" %>
      </div>
    <% end %>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if @legal_prompts.any? %>
      <% @legal_prompts.each do |prompt| %>
        <%= link_to prompt, class: "group" do %>
          <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 overflow-hidden border border-gray-100">
            <!-- Category Header -->
            <div class="bg-gradient-to-r from-emerald-50 to-green-50 px-6 py-3 border-b border-emerald-100">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-white text-emerald-700 shadow-sm">
                <%= prompt.category_korean %>
              </span>
            </div>
            
            <!-- Content -->
            <div class="p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-emerald-600 transition-colors line-clamp-2">
                <%= prompt.title %>
              </h3>
              <p class="text-sm text-gray-600 mb-4 line-clamp-3">
                <%= truncate(prompt.content, length: 100) %>
              </p>
              
              <!-- Tags -->
              <% if prompt.tags.any? %>
                <div class="flex flex-wrap gap-1 mb-4">
                  <% prompt.tags.limit(3).each do |tag| %>
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                      #<%= tag.name %>
                    </span>
                  <% end %>
                  <% if prompt.tags.count > 3 %>
                    <span class="inline-flex items-center px-2 py-1 text-xs text-gray-500">
                      +<%= prompt.tags.count - 3 %>
                    </span>
                  <% end %>
                </div>
              <% end %>
              
              <!-- Footer -->
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <div class="flex items-center space-x-2">
                  <div class="w-8 h-8 bg-emerald-100 rounded-full flex items-center justify-center">
                    <span class="text-xs font-medium text-emerald-700">
                      <%= prompt.user.name.first %>
                    </span>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-gray-700"><%= prompt.user.name %></p>
                    <p class="text-xs text-gray-500"><%= time_ago_in_words(prompt.created_at) %>전</p>
                  </div>
                </div>
                <svg class="w-5 h-5 text-gray-400 group-hover:text-emerald-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="col-span-full">
        <div class="bg-gray-50 rounded-2xl p-12 text-center">
          <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <h3 class="text-lg font-medium text-gray-900 mb-2">아직 등록된 프롬프트가 없습니다</h3>
          <p class="text-gray-600 mb-6">첫 번째 프롬프트를 등록하고 동료들과 공유해보세요!</p>
          <% if user_signed_in? %>
            <%= link_to "첫 프롬프트 등록하기", new_legal_prompt_path, 
                class: "inline-flex items-center px-6 py-3 bg-emerald-600 text-white font-medium rounded-xl hover:bg-emerald-700 transition duration-200" %>
          <% else %>
            <%= link_to "로그인하기", new_user_session_path, 
                class: "inline-flex items-center px-6 py-3 bg-emerald-600 text-white font-medium rounded-xl hover:bg-emerald-700 transition duration-200" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- CTA Section -->
<% unless user_signed_in? %>
  <div class="bg-gradient-to-r from-emerald-600 to-green-600 py-16 mt-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">
        지금 바로 시작하세요
      </h2>
      <p class="text-xl text-emerald-100 mb-8">
        무료로 가입하고 AI 프롬프트로 업무 효율을 높이세요
      </p>
      <%= link_to new_user_registration_path, 
          class: "inline-flex items-center px-8 py-4 text-base font-medium rounded-xl text-emerald-700 bg-white hover:bg-gray-100 transform hover:scale-105 transition-all duration-200 shadow-lg" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
        </svg>
        무료로 회원가입
      <% end %>
    </div>
  </div>
<% end %>
<%= form_with(model: legal_prompt, local: true, data: { turbo: false }) do |form| %>
  <% if legal_prompt.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
      <h3 class="font-bold mb-2"><%= pluralize(legal_prompt.errors.count, "error") %> prohibited this prompt from being saved:</h3>
      <ul class="list-disc list-inside">
        <% legal_prompt.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-6">
    <%= form.label :title, "제목*", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_field :title, 
        class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent",
        placeholder: "예: 계약서 검토 프롬프트" %>
  </div>

  <div class="mb-6">
    <%= form.label :category, "카테고리*", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.select :category, 
        options_for_select(LegalPrompt.categories.map {|key, value| [I18n.t("legal_prompt.categories.#{key}"), key]}, legal_prompt.category),
        { prompt: "선택하세요" },
        class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" %>
  </div>

  <div class="mb-6">
    <%= form.label :content, "프롬프트 내용*", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_area :content, 
        rows: 10,
        class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent",
        placeholder: "AI에게 전달할 프롬프트 내용을 입력하세요..." %>
  </div>

  <div class="mb-6">
    <%= form.label :tag_list, "태그", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_field :tag_list, 
        value: legal_prompt.tag_list,
        class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent",
        placeholder: "예: 계약서, 검토, 민사 (쉼표로 구분)" %>
    <p class="mt-1 text-sm text-gray-500">태그를 쉼표로 구분하여 입력하세요</p>
  </div>

  <div class="flex justify-end space-x-4">
    <%= link_to "취소", legal_prompts_path, 
        class: "px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 transition duration-200" %>
    <%= form.submit legal_prompt.new_record? ? "저장" : "수정", 
        class: "px-6 py-2 bg-emerald-600 text-white rounded hover:bg-emerald-700 transition duration-200 cursor-pointer" %>
  </div>
<% end %>